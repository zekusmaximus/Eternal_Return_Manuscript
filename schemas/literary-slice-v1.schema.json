{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zekusmaximus/Eternal_Return_Manuscript/schemas/literary-slice-v1.schema.json",
  "title": "Eternal Return literary vertical slice v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contentSha256", "payload", "schemaVersion"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "contentSha256": { "$ref": "#/$defs/sha256" },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseRelease",
        "context",
        "doNotEdit",
        "format",
        "manifest",
        "mappings",
        "runtimeTargets"
      ],
      "properties": {
        "format": { "const": "eternal-return-literary-slice" },
        "doNotEdit": { "type": "string", "minLength": 1 },
        "baseRelease": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifactFile",
            "contentSha256",
            "editorialReleaseId",
            "schemaVersion",
            "sourceCommit"
          ],
          "properties": {
            "artifactFile": { "$ref": "#/$defs/safePath" },
            "contentSha256": { "$ref": "#/$defs/sha256" },
            "editorialReleaseId": { "$ref": "#/$defs/stableId" },
            "schemaVersion": { "const": "1.0.0" },
            "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
          }
        },
        "manifest": { "type": "object" },
        "runtimeTargets": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "object" }
        },
        "mappings": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "object" }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chapters",
            "chronology",
            "philosophicalConstraints",
            "promisePayoffs",
            "voices"
          ],
          "properties": {
            "chapters": { "type": "array", "minItems": 1 },
            "chronology": { "type": "array", "minItems": 1 },
            "philosophicalConstraints": { "type": "array", "minItems": 1 },
            "promisePayoffs": { "type": "array", "minItems": 1 },
            "voices": { "type": "array", "minItems": 1 }
          }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "stableId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "safePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[A-Za-z0-9._/-]+$"
    }
  }
}
